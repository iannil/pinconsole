{
  "name": "@marketing-monitor/visitor-sdk",
  "version": "0.1.0",
  "description": "Visitor-side SDK for marketing-monitor (rrweb capture + WebSocket transport + operator command reception)",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/sdk.js",
  "module": "./dist/sdk.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,html}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "rrweb": "^2.0.0-alpha.18",
    "rrweb-snapshot": "^2.0.0-alpha.18"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.2"
  }
}

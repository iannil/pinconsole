# marketing-monitor 本地开发环境配置
# 复制此文件为 .env 并按需修改。.env 已 gitignore。
# docker-compose 自动读取根目录 .env。
#
# 1k fail-secure 提示：
#   - SERVER_ENV 默认 prod；本地开发需显式设 dev。
#   - ADMIN_PASSWORD 无默认值；本地开发也必须显式设。
#   - prod profile (docker compose --profile prod up) 强制要求 PG_PASSWORD /
#     MINIO_ACCESS_KEY / MINIO_SECRET_KEY / ADMIN_EMAIL / ADMIN_PASSWORD。

# ===== Server =====
SERVER_PORT=8080
SERVER_ENV=dev
LOG_LEVEL=info
# 1f：navigate 命令允许的额外域名（逗号分隔，留空仅同源+localhost）
NAVIGATE_ALLOWED_DOMAINS=
# 1h：初始 admin 用户（dev 也需设；prod 必须改强密码）
ADMIN_EMAIL=admin@marketing-monitor.local
ADMIN_PASSWORD=changeme123
# 1k：bcrypt cost（项目要求 ≥ 12）
BCRYPT_COST=12

# ===== PostgreSQL =====
PG_HOST=localhost
PG_PORT=5432
PG_USER=mm
PG_PASSWORD=mm_dev
PG_DB=marketing_monitor
# 1k：SSL 模式（prefer/require/verify-full；prod 推荐 require）
PG_SSLMODE=prefer

# docker-compose 内部连接（容器间使用）
PG_HOST_DOCKER=postgres
PG_PORT_DOCKER=5432

# ===== Redis =====
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

REDIS_HOST_DOCKER=redis
REDIS_PORT_DOCKER=6379

# ===== MinIO =====
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=mm_dev
MINIO_SECRET_KEY=mm_dev_secret
MINIO_BUCKET=marketing-monitor
MINIO_USE_SSL=false

MINIO_HOST_DOCKER=minio
MINIO_PORT_DOCKER=9000

# MinIO Console（仅容器内访问，host 端口在 compose 里映射）
MINIO_CONSOLE_PORT=9001

# pinconsole 本地开发环境配置
# 复制此文件为 .env 并按需修改。.env 已 gitignore。
# docker-compose 自动读取根目录 .env。
#
# 1k fail-secure 提示：
#   - SERVER_ENV 默认 prod；本地开发需显式设 dev。
#   - ADMIN_PASSWORD 无默认值；本地开发也必须显式设。
#   - prod profile (docker compose --profile prod up) 强制要求 PG_PASSWORD /
#     MINIO_ACCESS_KEY / MINIO_SECRET_KEY / ADMIN_EMAIL / ADMIN_PASSWORD。
#
# 1z fail-secure 补充：
#   - SERVER_ENV 仅允许 {prod, dev, test}；typo 如 "production" 启动直接拒绝
#     (防 dev mode bypass 在 dev 二进制下静默生效)。
#   - prod 模式 + 远程 PG/MinIO 下,强制 PG_SSLMODE≠disable + MINIO_USE_SSL=true
#     (本机 / docker 容器间允许 false)。
#   - 1z 默认 PG_MAX_CONNS=25 / REDIS_POOL_SIZE=50,覆盖 4 核机器 pgx/go-redis 默认 4/40。

# ===== Server =====
SERVER_PORT=7080
SERVER_ENV=dev
LOG_LEVEL=info
# 1f：navigate 命令允许的额外域名（逗号分隔，留空仅同源+localhost）
NAVIGATE_ALLOWED_DOMAINS=
# 1h：初始 admin 用户（dev 也需设；prod 必须改强密码）
ADMIN_EMAIL=admin@pinconsole.local
ADMIN_PASSWORD=changeme123
# 1k：bcrypt cost（项目要求 ≥ 12）
BCRYPT_COST=12
# 1o/1ab:部署在 nginx/caddy 后必填,逗号分隔 CIDR (如 10.0.0.0/8,192.168.0.0/16)。
# 留空 = 不信任任何反代 → ClientIP() 用 RemoteAddr → 部署在反代后所有请求看上去都来自反代 IP
# → rate limit 共用单 IP 预算。
TRUSTED_PROXIES=
# 1ab P1-5:显式声明部署拓扑。
# true = 部署在反代后(validate 启动时强制要求 TRUSTED_PROXIES 配置)
# false/默认 = 直接暴露(TRUSTED_PROXIES 应为空,XFF 被忽略防伪造)
BEHIND_REVERSE_PROXY=false

# ===== PostgreSQL =====
PG_HOST=localhost
PG_PORT=7032
PG_USER=mm
PG_PASSWORD=mm_dev
PG_DB=pinconsole
# 1k：SSL 模式（prefer/require/verify-full；prod 推荐 require）
PG_SSLMODE=prefer
# 1z：连接池上限 (默认 25)。pgx 默认 max(4, NumCPU) 对 4 核机器仅 4 条。
# 每 visitor session 占用 1 PG 写连接,建议 ≥ 期望并发 visitor 数 + 5 (运营+GC)。
PG_MAX_CONNS=25

# ===== Redis =====
REDIS_ADDR=localhost:7079
REDIS_PORT=7079
REDIS_PASSWORD=
# 1z：连接池上限 (默认 50)。go-redis 默认 10*NumCPU 对 4 核机器仅 40 条。
# rate limit + claim + stream append + presence 多 key 类操作很快耗尽。
REDIS_POOL_SIZE=50

# ===== MinIO =====
MINIO_ENDPOINT=localhost:7020
MINIO_ACCESS_KEY=mm_dev
MINIO_SECRET_KEY=mm_dev_secret
MINIO_BUCKET=pinconsole
MINIO_USE_SSL=false

# MinIO Console（仅容器内访问，host 端口在 compose 里映射）
MINIO_CONSOLE_PORT=7021
# docker-compose host port mapping
REDIS_PORT=7079

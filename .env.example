# marketing-monitor 本地开发环境配置
# 复制此文件为 .env 并按需修改。.env 已 gitignore。
# docker-compose 自动读取根目录 .env。

# ===== Server =====
SERVER_PORT=8080
SERVER_ENV=dev
LOG_LEVEL=info

# ===== PostgreSQL =====
PG_HOST=localhost
PG_PORT=5432
PG_USER=mm
PG_PASSWORD=mm_dev
PG_DB=marketing_monitor

# docker-compose 内部连接（容器间使用）
PG_HOST_DOCKER=postgres
PG_PORT_DOCKER=5432

# ===== Redis =====
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

REDIS_HOST_DOCKER=redis
REDIS_PORT_DOCKER=6379

# ===== MinIO =====
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=mm_dev
MINIO_SECRET_KEY=mm_dev_secret
MINIO_BUCKET=marketing-monitor
MINIO_USE_SSL=false

MINIO_HOST_DOCKER=minio
MINIO_PORT_DOCKER=9000

# MinIO Console（仅容器内访问，host 端口在 compose 里映射）
MINIO_CONSOLE_PORT=9001

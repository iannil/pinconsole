---
import type { PageContent } from '../content/types';

interface Props {
  content: PageContent;
}

const { content } = Astro.props;
const faq = content.faq;
const ordinal = (n: number) => (n + 1).toString().padStart(2, '0');
---

<section id="faq" class="section faq-section">
  <div class="container container-wide">
    <header class="section-header reveal">
      <span class="section-number">04 — {faq.eyebrow}</span>
      <h2 class="headline">{faq.title}</h2>
      <p class="lead section-subtitle">{faq.subtitle}</p>
    </header>

    <ol class="faq-grid">
      {faq.items.map((item, i) => (
        <li class="faq-card reveal" style={`--reveal-delay:${i % 2}`}>
          <div class="faq-card-head">
            <span class="faq-numeral">{ordinal(i)}</span>
            <span class="faq-marker" aria-hidden="true"></span>
          </div>
          <h3 class="faq-question-text">{item.question}</h3>
          <p class="faq-answer">{item.answer}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .faq-section {
    background: var(--pc-color-bg-canvas);
    border-bottom: 1px solid var(--pc-color-border-default);
  }

  .section-header {
    max-width: 720px;
    margin-bottom: 48px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .faq-grid {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border-top: 1px solid var(--pc-color-border-default);
  }

  .faq-card {
    padding: 28px 32px;
    border-bottom: 1px solid var(--pc-color-border-default);
    border-right: 1px solid var(--pc-color-border-default);
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: background-color var(--pc-duration-fast) var(--pc-easing);
  }

  .faq-card:nth-child(2n) {
    border-right: none;
  }

  .faq-card:hover {
    background: var(--pc-color-bg-surface);
  }

  .faq-card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2px;
  }

  .faq-numeral {
    font-family: var(--pc-font-mono);
    font-size: var(--pc-text-micro);
    color: var(--pc-color-text-muted);
    letter-spacing: 0.06em;
    font-weight: var(--pc-weight-medium);
  }

  .faq-marker {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--pc-color-accent-default);
    opacity: 0;
    transition: opacity var(--pc-duration-fast) var(--pc-easing);
  }

  .faq-card:hover .faq-marker {
    opacity: 1;
  }

  .faq-question-text {
    font-family: var(--pc-font-sans);
    font-size: var(--pc-text-title);
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--pc-color-text-primary);
    margin: 0;
    transition: color var(--pc-duration-fast) var(--pc-easing);
  }

  :lang(zh) .faq-question-text,
  :lang(zh-CN) .faq-question-text {
    font-family: var(--pc-font-sans-zh);
    letter-spacing: 0;
  }

  .faq-card:hover .faq-question-text {
    color: var(--pc-color-accent-hover);
  }

  .faq-answer {
    color: var(--pc-color-text-secondary);
    font-size: var(--pc-text-body-sm);
    line-height: var(--pc-line-relaxed);
    margin: 0;
    font-family: var(--pc-font-sans);
  }

  :lang(zh) .faq-answer,
  :lang(zh-CN) .faq-answer {
    font-family: var(--pc-font-sans-zh);
  }

  @media (max-width: 880px) {
    .faq-grid {
      grid-template-columns: 1fr;
    }
    .faq-card {
      padding: 24px 0;
      border-right: none;
    }
  }
</style>

---
import type { PageContent } from '../content/types';
import PhosphorIcon from './PhosphorIcon.astro';

interface Props {
  content: PageContent;
}

const { content } = Astro.props;
const p = content.problem;
---

<section class="section problem-section">
  <div class="container">
    <div class="section-header reveal">
      <span class="eyebrow">{p.eyebrow}</span>
      <h2 class="section-title">{p.title}</h2>
      <p class="section-subtitle">{p.subtitle}</p>
    </div>

    <div class="problem-grid">
      {p.items.map((item, i) => (
        <article class="card problem-card reveal" style={`--i:${i}`}>
          <div class="problem-icon">
            <PhosphorIcon name={item.icon} size={28} weight="regular" color="accent" />
          </div>
          <h3 class="problem-title">{item.title}</h3>
          <p class="problem-description">{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .problem-section {
    background: var(--pc-color-bg-canvas);
  }

  .section-header {
    max-width: 720px;
    margin-bottom: 56px;
  }

  .problem-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .problem-card {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 32px;
  }

  .problem-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    background: var(--pc-color-accent-subtle);
    border-radius: var(--pc-radius-lg);
    color: var(--pc-color-accent-default);
  }

  .problem-title {
    font-size: var(--pc-text-section-h3);
    font-weight: var(--pc-weight-semibold);
    color: var(--pc-color-text-primary);
    letter-spacing: -0.02em;
  }

  .problem-description {
    color: var(--pc-color-text-secondary);
    font-size: var(--pc-text-body);
    line-height: var(--pc-line-relaxed);
  }

  @media (max-width: 960px) {
    .problem-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

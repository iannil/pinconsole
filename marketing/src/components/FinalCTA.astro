---
import type { PageContent } from '../content/types';
import PhosphorIcon from './PhosphorIcon.astro';
import LeadForm from './LeadForm.vue';

interface Props {
  content: PageContent;
}

const { content } = Astro.props;
const cta = content.finalCTA;
const isZh = content.locale === 'zh';

const trustBadges = isZh
  ? [
      { icon: 'clock-countdown', label: '48 小时人回复' },
      { icon: 'lock-key', label: '数据在 maintainer 自托管 D1' },
      { icon: 'shield-check', label: '不分享第三方 / 可申请删除' },
    ]
  : [
      { icon: 'clock-countdown', label: '48h human reply' },
      { icon: 'lock-key', label: 'Data in maintainer self-hosted D1' },
      { icon: 'shield-check', label: 'Not shared / deletable on request' },
    ];
---

<section id="consult" class="section final-cta-section">
  <div class="container">
    <header class="cta-header reveal">
      <span class="section-number">05 — {cta.eyebrow}</span>
    </header>

    <!-- Band 1: manifesto title -->
    <div class="cta-manifesto reveal">
      <h2 class="manifesto-title">{cta.title}<span class="accent-period" aria-hidden="true">.</span></h2>
      <p class="lead cta-subtitle">{cta.subtitle}</p>
    </div>

    <!-- Band 2: 3 trust badges -->
    <ol class="trust-badges reveal">
      {trustBadges.map((badge, i) => (
        <li class="trust-badge" style={`--reveal-delay:${i}`}>
          <span class="badge-icon" aria-hidden="true">
            <PhosphorIcon name={badge.icon} size={14} weight="bold" />
          </span>
          <span class="badge-label">{badge.label}</span>
        </li>
      ))}
    </ol>

    <!-- Band 3: centered form -->
    <div class="cta-form-wrap reveal">
      <div class="cta-form-card">
        <header class="form-header">
          <span class="form-label">{isZh ? '咨询表单' : 'Consultation form'}</span>
          <span class="form-meta">— {isZh ? '必填项以 * 标注' : 'required fields marked *'}</span>
        </header>
        <LeadForm content={cta.form} locale={content.locale} client:load />
      </div>
    </div>
  </div>
</section>

<style>
  .final-cta-section {
    background: var(--pc-color-bg-canvas);
    border-bottom: 1px solid var(--pc-color-border-default);
    position: relative;
    overflow: hidden;
    text-align: center;
  }

  /* Stronger emerald spotlight behind CTA */
  .final-cta-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 50% 60% at 50% 30%,
      var(--pc-spotlight-color) 0%,
      transparent 60%
    );
    pointer-events: none;
  }

  .cta-header {
    position: relative;
    margin-bottom: 32px;
  }

  .cta-header .section-number {
    display: inline-block;
  }

  /* ===== Band 1: manifesto ===== */
  .cta-manifesto {
    position: relative;
    max-width: 800px;
    margin: 0 auto 40px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: center;
  }

  .manifesto-title {
    font-family: var(--pc-font-sans);
    font-size: var(--pc-text-display);
    font-weight: 600;
    line-height: var(--pc-line-display);
    letter-spacing: -0.025em;
    color: var(--pc-color-text-primary);
    margin: 0;
    text-align: center;
  }

  :lang(zh) .manifesto-title,
  :lang(zh-CN) .manifesto-title {
    font-family: var(--pc-font-sans-zh);
    letter-spacing: -0.01em;
  }

  .accent-mark {
    color: var(--pc-color-accent-default);
  }

  .accent-period {
    color: var(--pc-color-accent-default);
    font-weight: 700;
    margin-left: 2px;
  }

  .cta-subtitle {
    max-width: 56ch;
    margin: 0 auto;
    text-align: center;
  }

  /* ===== Band 2: trust badges ===== */
  .trust-badges {
    list-style: none;
    display: flex;
    justify-content: center;
    align-items: stretch;
    flex-wrap: wrap;
    gap: 0;
    margin-bottom: 48px;
    position: relative;
    border-top: 1px solid var(--pc-color-border-default);
    border-bottom: 1px solid var(--pc-color-border-default);
  }

  .trust-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 18px 28px;
    border-right: 1px solid var(--pc-color-border-default);
    flex: 1;
    justify-content: center;
    min-width: 240px;
  }

  .trust-badge:last-child {
    border-right: none;
  }

  .badge-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: var(--pc-color-accent-subtle);
    border: 1px solid color-mix(in srgb, var(--pc-color-accent-default) 30%, transparent);
    border-radius: var(--pc-radius-sm);
    color: var(--pc-color-accent-default);
    flex-shrink: 0;
  }

  .badge-label {
    font-family: var(--pc-font-mono);
    font-size: var(--pc-text-caption);
    color: var(--pc-color-text-primary);
    letter-spacing: 0.02em;
    text-align: left;
    line-height: 1.4;
  }

  :lang(zh) .badge-label,
  :lang(zh-CN) .badge-label {
    font-family: var(--pc-font-sans-zh);
  }

  /* ===== Band 3: centered form ===== */
  .cta-form-wrap {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .cta-form-card {
    background: var(--pc-color-bg-surface);
    border: 1px solid var(--pc-color-border-strong);
    border-radius: var(--pc-radius-lg);
    padding: 28px;
    width: 100%;
    max-width: 560px;
    text-align: left;
    box-shadow: var(--pc-shadow-lg);
  }

  .form-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    padding-bottom: 16px;
    margin-bottom: 20px;
    border-bottom: 1px solid var(--pc-color-border-default);
  }

  .form-label {
    font-family: var(--pc-font-mono);
    font-size: var(--pc-text-micro);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--pc-color-text-primary);
    font-weight: var(--pc-weight-semibold);
  }

  .form-meta {
    font-family: var(--pc-font-mono);
    font-size: 10px;
    color: var(--pc-color-text-muted);
    letter-spacing: 0.04em;
  }

  /* Vue form styling via :global */
  :global(.lead-form) {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  :global(.lead-form-field) {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  :global(.lead-form-label) {
    font-family: var(--pc-font-mono);
    font-size: 10px;
    font-weight: var(--pc-weight-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--pc-color-text-primary);
  }

  :global(.lead-form-input),
  :global(.lead-form-textarea),
  :global(.lead-form-select) {
    width: 100%;
    padding: 10px 14px;
    background: var(--pc-color-bg-elevated);
    border: 1px solid var(--pc-color-border-default);
    border-radius: var(--pc-radius-sm);
    color: var(--pc-color-text-primary);
    font-size: var(--pc-text-body-sm);
    font-family: var(--pc-font-sans);
    transition: border-color var(--pc-duration-fast) var(--pc-easing),
                background-color var(--pc-duration-fast) var(--pc-easing);
  }

  :global(.lead-form-input:focus),
  :global(.lead-form-textarea:focus),
  :global(.lead-form-select:focus) {
    outline: none;
    border-color: var(--pc-color-accent-default);
    background: var(--pc-color-bg-canvas);
  }

  :global(.lead-form-input::placeholder),
  :global(.lead-form-textarea::placeholder) {
    color: var(--pc-color-text-muted);
  }

  :global(.lead-form-textarea) {
    min-height: 80px;
    resize: vertical;
    font-family: inherit;
  }

  :global(.lead-form-submit) {
    width: 100%;
    padding: 12px 20px;
    background: var(--pc-color-accent-default);
    color: var(--pc-color-accent-on);
    border: none;
    border-radius: var(--pc-radius-sm);
    font-family: var(--pc-font-mono);
    font-size: var(--pc-text-caption);
    font-weight: var(--pc-weight-semibold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background-color var(--pc-duration-fast) var(--pc-easing);
  }

  :global(.lead-form-submit:hover:not(:disabled)) {
    background: var(--pc-color-accent-hover);
  }

  :global(.lead-form-submit:disabled) {
    opacity: 0.5;
    cursor: not-allowed;
  }

  :global(.lead-form-privacy) {
    font-family: var(--pc-font-sans);
    font-size: var(--pc-text-micro);
    color: var(--pc-color-text-muted);
    line-height: 1.5;
    margin-top: 2px;
    text-align: center;
  }

  :global(.lead-form-message) {
    padding: 10px 14px;
    border-radius: var(--pc-radius-sm);
    font-size: var(--pc-text-body-sm);
    text-align: center;
    font-family: var(--pc-font-sans);
  }

  :global(.lead-form-message.success) {
    background: var(--pc-color-accent-subtle);
    color: var(--pc-color-accent-default);
    border: 1px solid color-mix(in srgb, var(--pc-color-accent-default) 30%, transparent);
  }

  :global(.lead-form-message.error) {
    background: var(--pc-color-danger-subtle);
    color: var(--pc-color-danger);
    border: 1px solid color-mix(in srgb, var(--pc-color-danger) 30%, transparent);
  }

  :global(.lead-form-honeypot) {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  @media (max-width: 880px) {
    .cta-form-card {
      padding: 20px;
    }
    .trust-badge {
      padding: 14px 20px;
      min-width: 0;
      border-right: none;
      border-bottom: 1px solid var(--pc-color-border-default);
    }
    .trust-badge:last-child {
      border-bottom: none;
    }
  }
</style>

---
import type { PageContent } from '../content/types';
import PhosphorIcon from './PhosphorIcon.astro';

interface Props {
  content: PageContent;
}

const { content } = Astro.props;
const f = content.features;
---

<section id="features" class="section features-section">
  <div class="container">
    <div class="section-header reveal">
      <span class="eyebrow">{f.eyebrow}</span>
      <h2 class="section-title">{f.title}</h2>
      <p class="section-subtitle">{f.subtitle}</p>
    </div>

    <div class="features-list">
      {f.items.map((item, i) => (
        <article class="feature-row reveal" style={`--i:${i}`}>
          <div class="feature-copy">
            <div class="feature-icon">
              <PhosphorIcon name={item.icon} size={28} weight="regular" color="accent" />
            </div>
            <h3 class="feature-title">{item.title}</h3>
            <p class="feature-description">{item.description}</p>
            <ul class="feature-bullets">
              {item.bullets.map((b) => (
                <li>
                  <PhosphorIcon name="check-circle" size={16} weight="regular" color="success" />
                  <span>{b}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="feature-screenshot">
            {item.screenshot ? (
              <img
                src={item.screenshot}
                alt={`${item.title} — pinconsole admin`}
                loading="lazy"
                decoding="async"
                width="800"
                height="600"
              />
            ) : (
              <div class="screenshot-placeholder">
                <PhosphorIcon name="eye" size={32} weight="light" />
                <span>screenshot</span>
              </div>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .features-section {
    background: var(--pc-color-bg-surface);
    border-block: 1px solid var(--pc-color-border-default);
  }

  .section-header {
    max-width: 720px;
    margin-bottom: 64px;
  }

  .features-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .feature-row {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 48px;
    align-items: center;
    padding-block: 48px;
    border-bottom: 1px solid var(--pc-color-border-default);
  }

  .feature-row:last-child {
    border-bottom: none;
  }

  .feature-row:nth-child(even) {
    direction: rtl;
  }
  .feature-row:nth-child(even) > * {
    direction: ltr;
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    background: var(--pc-color-accent-subtle);
    border-radius: var(--pc-radius-lg);
    color: var(--pc-color-accent-default);
    margin-bottom: 20px;
  }

  .feature-title {
    font-size: var(--pc-text-section-h3);
    font-weight: var(--pc-weight-semibold);
    color: var(--pc-color-text-primary);
    letter-spacing: -0.02em;
    margin-bottom: 12px;
  }

  .feature-description {
    color: var(--pc-color-text-secondary);
    font-size: var(--pc-text-body);
    line-height: var(--pc-line-relaxed);
    margin-bottom: 20px;
  }

  .feature-bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .feature-bullets li {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: var(--pc-text-body-sm);
    color: var(--pc-color-text-primary);
  }

  .feature-screenshot {
    aspect-ratio: 4 / 3;
    border-radius: var(--pc-radius-lg);
    box-shadow: var(--pc-shadow-md);
    overflow: hidden;
    border: 1px solid var(--pc-color-border-default);
    background: var(--pc-color-bg-canvas);
    transition: transform var(--pc-duration-slow) var(--pc-easing),
                box-shadow var(--pc-duration-slow) var(--pc-easing);
  }

  .feature-row:hover .feature-screenshot {
    transform: translateY(-2px);
    box-shadow: var(--pc-shadow-lg);
  }

  .feature-screenshot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  .screenshot-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    color: var(--pc-color-text-muted);
    font-size: var(--pc-text-caption);
    font-family: var(--pc-font-mono);
  }

  @media (max-width: 960px) {
    .feature-row,
    .feature-row:nth-child(even) {
      grid-template-columns: 1fr;
      direction: ltr;
      gap: 24px;
    }
  }
</style>

---
import type { PageContent } from '../content/types';
import Logo from './Logo.astro';
import PhosphorIcon from './PhosphorIcon.astro';

interface Props {
  content: PageContent;
}

const { content } = Astro.props;
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label="PinConsole">
      <Logo size={20} />
      <span class="brand-word">PinConsole</span>
    </a>

    <nav class="nav-links" aria-label="primary">
      {content.nav.links.filter((link) => !link.href.startsWith('http')).map((link) => (
        <a href={link.href} class="nav-item">
          <span class="nav-label">{link.label}</span>
        </a>
      ))}
    </nav>

    <div class="nav-actions">
      <a
        href="https://github.com/iannil/pinconsole"
        class="util-chip"
        target="_blank"
        rel="noopener"
        aria-label="GitHub"
      >
        <PhosphorIcon name="github" size={16} weight="regular" />
      </a>
      <a href={content.nav.localeSwitch.href} class="util-chip locale-chip" aria-label="switch language">
        {content.nav.localeSwitch.label}
      </a>
      <a href="#consult" class="btn btn-primary header-cta">{content.nav.cta}</a>
    </div>
  </div>

  <div class="credibility-strip" aria-label="project facts">
    <div class="container credibility-inner">
      <span class="cred-item">
        <span class="cred-dot" aria-hidden="true"></span>
        <span class="cred-value">AGPL-3.0</span>
      </span>
      <span class="cred-item">
        <span class="cred-dot" aria-hidden="true"></span>
        <span class="cred-value">{content.locale === 'zh' ? '自托管' : 'self-hosted'}</span>
      </span>
      <span class="cred-item">
        <span class="cred-dot" aria-hidden="true"></span>
        <span class="cred-value">GDPR-ready</span>
      </span>
      <span class="cred-item">
        <span class="cred-dot" aria-hidden="true"></span>
        <span class="cred-value">{content.locale === 'zh' ? '48h 人回复' : '48h human reply'}</span>
      </span>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--pc-z-header);
    background: color-mix(in srgb, var(--pc-color-bg-canvas) 88%, transparent);
    backdrop-filter: saturate(160%) blur(12px);
    -webkit-backdrop-filter: saturate(160%) blur(12px);
    border-bottom: 1px solid var(--pc-color-border-default);
  }

  .header-inner {
    height: var(--pc-header-height);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--pc-font-sans);
    font-size: 15px;
    font-weight: 600;
    color: var(--pc-color-text-primary);
    letter-spacing: -0.01em;
  }

  .brand-word {
    font-family: var(--pc-font-mono);
    font-weight: 500;
  }

  :lang(zh) .brand-word,
  :lang(zh-CN) .brand-word {
    font-family: var(--pc-font-sans-zh);
  }

  .brand:hover {
    color: var(--pc-color-text-primary);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 28px;
    flex: 1;
    justify-content: flex-start;
  }

  .nav-item {
    position: relative;
  }

  .nav-label {
    font-family: var(--pc-font-sans);
    font-size: var(--pc-text-body-sm);
    font-weight: var(--pc-weight-regular);
    color: var(--pc-color-text-secondary);
    transition: color var(--pc-duration-fast) var(--pc-easing);
  }

  :lang(zh) .nav-label,
  :lang(zh-CN) .nav-label {
    font-family: var(--pc-font-sans-zh);
  }

  .nav-item:hover .nav-label {
    color: var(--pc-color-text-primary);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  /* Shared utility chip — used for GitHub icon + locale switch */
  .util-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 32px;
    height: 32px;
    padding: 0 10px;
    border: 1px solid var(--pc-color-border-default);
    border-radius: var(--pc-radius-sm);
    color: var(--pc-color-text-secondary);
    background: transparent;
    transition: color var(--pc-duration-fast) var(--pc-easing),
                border-color var(--pc-duration-fast) var(--pc-easing),
                background-color var(--pc-duration-fast) var(--pc-easing);
  }

  .util-chip:hover {
    color: var(--pc-color-text-primary);
    border-color: var(--pc-color-border-strong);
    background: var(--pc-color-bg-elevated);
  }

  .locale-chip {
    font-family: var(--pc-font-mono);
    font-size: var(--pc-text-caption);
    font-weight: var(--pc-weight-medium);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .header-cta {
    padding: 7px 14px;
    font-size: var(--pc-text-body-sm);
  }

  /* ===== Credibility strip ===== */
  .credibility-strip {
    border-top: 1px solid var(--pc-color-border-default);
    background: color-mix(in srgb, var(--pc-color-bg-canvas) 60%, transparent);
  }

  .credibility-inner {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 28px;
    height: 36px;
    flex-wrap: nowrap;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .credibility-inner::-webkit-scrollbar {
    display: none;
  }

  .cred-item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--pc-font-mono);
    font-size: var(--pc-text-micro);
    color: var(--pc-color-text-primary);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
    font-weight: var(--pc-weight-medium);
  }

  :lang(zh) .cred-item,
  :lang(zh-CN) .cred-item {
    font-family: var(--pc-font-sans-zh);
    letter-spacing: 0;
    text-transform: none;
  }

  .cred-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--pc-color-accent-default);
    box-shadow: 0 0 6px color-mix(in srgb, var(--pc-color-accent-default) 60%, transparent);
    flex-shrink: 0;
  }

  @media (max-width: 880px) {
    .nav-links {
      display: none;
    }
  }

  @media (max-width: 600px) {
    .locale-chip {
      display: none;
    }
    .credibility-inner {
      gap: 16px;
    }
    .cred-item {
      font-size: 10px;
    }
  }
</style>

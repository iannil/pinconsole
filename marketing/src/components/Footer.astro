---
import type { PageContent } from '../content/types';
import Logo from './Logo.astro';

interface Props {
  content: PageContent;
}

const { content } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand-block">
        <a href="/" class="footer-brand" aria-label="PinConsole">
          <Logo size={18} />
          <span class="footer-word">PinConsole</span>
        </a>
        <p class="footer-tagline">{content.footer.tagline}</p>
      </div>

      <div class="footer-cols">
        {content.footer.columns.map((col) => (
          <div class="footer-col">
            <span class="col-label">{col.title}</span>
            <ul>
              {col.links.map((link) => (
                <li><a href={link.href}>{link.label}</a></li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <hr class="footer-rule" />

    <div class="footer-bottom">
      <span class="footer-meta">
        <span class="meta-item">{content.footer.license}</span>
        <span class="meta-sep" aria-hidden="true">·</span>
        <span class="meta-item">{content.footer.sourceNote.replace('2026', String(year))}</span>
      </span>
      <span class="footer-status">
        <span class="status-dot" aria-hidden="true"></span>
        <span>{content.locale === 'zh' ? 'v1 现已交付' : 'v1 shipped'}</span>
      </span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--pc-color-bg-canvas);
    border-top: 1px solid var(--pc-color-border-default);
    padding-top: 64px;
    padding-bottom: 32px;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1.5fr 2fr;
    gap: 64px;
    padding-bottom: 48px;
  }

  .footer-brand-block {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-brand {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--pc-color-text-primary);
  }

  .footer-word {
    font-family: var(--pc-font-mono);
    font-size: 15px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--pc-color-text-primary);
  }

  :lang(zh) .footer-word,
  :lang(zh-CN) .footer-word {
    font-family: var(--pc-font-sans-zh);
  }

  .footer-tagline {
    font-family: var(--pc-font-sans);
    font-size: var(--pc-text-body);
    color: var(--pc-color-text-secondary);
    line-height: var(--pc-line-relaxed);
    max-width: 32ch;
  }

  :lang(zh) .footer-tagline,
  :lang(zh-CN) .footer-tagline {
    font-family: var(--pc-font-sans-zh);
  }

  .footer-cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .col-label {
    display: block;
    font-family: var(--pc-font-mono);
    font-size: var(--pc-text-micro);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--pc-color-text-muted);
    margin-bottom: 14px;
    font-weight: var(--pc-weight-medium);
  }

  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-col a {
    color: var(--pc-color-text-secondary);
    font-size: var(--pc-text-body-sm);
    transition: color var(--pc-duration-fast) var(--pc-easing);
    font-family: var(--pc-font-sans);
  }

  :lang(zh) .footer-col a,
  :lang(zh-CN) .footer-col a {
    font-family: var(--pc-font-sans-zh);
  }

  .footer-col a:hover {
    color: var(--pc-color-accent-default);
  }

  .footer-rule {
    border: 0;
    height: 1px;
    background: var(--pc-color-border-default);
    margin: 0;
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding-top: 24px;
    flex-wrap: wrap;
  }

  .footer-meta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--pc-font-mono);
    font-size: var(--pc-text-micro);
    color: var(--pc-color-text-muted);
    letter-spacing: 0.04em;
  }

  .meta-sep {
    color: var(--pc-color-text-muted);
    opacity: 0.5;
  }

  .footer-status {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--pc-font-mono);
    font-size: var(--pc-text-micro);
    color: var(--pc-color-text-secondary);
    letter-spacing: 0.04em;
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--pc-color-accent-default);
    box-shadow: 0 0 6px var(--pc-color-accent-default);
  }

  @media (max-width: 768px) {
    .footer-top {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .footer-cols {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>

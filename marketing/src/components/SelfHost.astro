---
import type { PageContent } from '../content/types';
import PhosphorIcon from './PhosphorIcon.astro';

interface Props {
  content: PageContent;
}

const { content } = Astro.props;
const s = content.selfHost;
const titleLines = s.title.split('\n');
---

<section id="self-host" class="section self-host-section">
  <div class="container">
    <div class="self-host-grid">
      <div class="self-host-copy reveal">
        <span class="eyebrow">{s.eyebrow}</span>
        <h2 class="section-title">
          {titleLines.map((line) => (
            <span class="title-line">{line}</span>
          ))}
        </h2>
        <p class="section-subtitle">{s.subtitle}</p>
        <a href={s.docsLink.href} class="docs-link" target="_blank" rel="noopener">
          <PhosphorIcon name="arrow-right" size={16} weight="bold" />
          {s.docsLink.label}
        </a>
      </div>

      <div class="self-host-code reveal">
        <div class="code-header">
          <div class="code-dots" aria-hidden="true">
            <span></span><span></span><span></span>
          </div>
          <span class="code-title">bash</span>
        </div>
        <pre class="code-block"><code set:html={s.code.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/^$/gm, '<span class="blank-line"> </span>')} /></pre>
      </div>
    </div>
  </div>
</section>

<style>
  .self-host-section {
    background: var(--pc-color-bg-surface);
    border-block: 1px solid var(--pc-color-border-default);
  }

  .self-host-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 64px;
    align-items: center;
  }

  .self-host-copy .title-line {
    display: block;
  }

  .docs-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 24px;
    font-weight: var(--pc-weight-medium);
    color: var(--pc-color-accent-default);
    transition: gap var(--pc-duration-fast) var(--pc-easing);
  }

  .docs-link:hover {
    gap: 10px;
  }

  .self-host-code {
    background: var(--pc-color-bg-inverse);
    border-radius: var(--pc-radius-xl);
    overflow: hidden;
    box-shadow: var(--pc-shadow-lg);
  }

  .code-header {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .code-dots {
    display: flex;
    gap: 6px;
  }

  .code-dots span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.18);
  }

  .code-dots span:nth-child(1) { background: #ff5f56; }
  .code-dots span:nth-child(2) { background: #ffbd2e; }
  .code-dots span:nth-child(3) { background: #27c93f; }

  .code-title {
    font-family: var(--pc-font-mono);
    font-size: var(--pc-text-caption);
    color: rgba(255, 255, 255, 0.5);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .code-block {
    margin: 0;
    background: transparent;
    padding: 24px;
    color: var(--pc-color-text-inverse);
    font-size: 14px;
    line-height: 1.7;
    overflow-x: auto;
    background: var(--pc-color-bg-inverse);
    border: none;
    border-radius: 0;
  }

  .code-block code {
    background: transparent;
    color: inherit;
    padding: 0;
  }

  .blank-line {
    display: block;
    height: 1em;
  }

  @media (max-width: 960px) {
    .self-host-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>

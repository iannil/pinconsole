---
import type { PageContent } from '../content/types';
import PhosphorIcon from './PhosphorIcon.astro';

interface Props {
  content: PageContent;
}

const { content } = Astro.props;
const d = content.dataSovereignty;
---

<section id="data-sovereignty" class="section data-section">
  <div class="container">
    <div class="section-header reveal">
      <span class="eyebrow">{d.eyebrow}</span>
      <h2 class="section-title">{d.title}</h2>
      <p class="section-subtitle">{d.subtitle}</p>
    </div>

    <div class="data-architecture reveal">
      <div class="arch-diagram" role="img" aria-label={d.architectureAlt}>
        <div class="arch-node arch-visitor">
          <PhosphorIcon name="eye" size={24} weight="regular" />
          <span>{content.locale === 'zh' ? '访客' : 'Visitor'}</span>
          <span class="arch-sub">SDK</span>
        </div>

        <div class="arch-arrow" aria-hidden="true">↔</div>

        <div class="arch-node arch-server">
          <PhosphorIcon name="stack" size={28} weight="bold" color="accent" />
          <span>pinconsole-server</span>
          <span class="arch-sub">{content.locale === 'zh' ? '你的服务器' : 'Your server'}</span>
        </div>

        <div class="arch-arrow" aria-hidden="true">→</div>

        <div class="arch-node arch-storage">
          <PhosphorIcon name="lock" size={24} weight="regular" />
          <span>{content.locale === 'zh' ? 'PostgreSQL · Redis · MinIO' : 'PostgreSQL · Redis · MinIO'}</span>
          <span class="arch-sub">{content.locale === 'zh' ? '你的存储' : 'Your storage'}</span>
        </div>

        <div class="arch-external" aria-hidden="true">
          <span>{content.locale === 'zh' ? '无外部依赖' : 'No external dependencies'}</span>
        </div>
      </div>
    </div>

    <div class="pillars-grid">
      {d.pillars.map((pillar, i) => (
        <article class="card pillar-card reveal" style={`--i:${i}`}>
          <div class="pillar-icon">
            <PhosphorIcon name={pillar.icon} size={32} weight="regular" color="accent" />
          </div>
          <h3 class="pillar-title">{pillar.title}</h3>
          <p class="pillar-description">{pillar.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .data-section {
    background: var(--pc-color-bg-canvas);
    position: relative;
  }

  .section-header {
    max-width: 720px;
    margin-bottom: 64px;
  }

  .data-architecture {
    margin-bottom: 64px;
  }

  .arch-diagram {
    background: var(--pc-color-bg-surface);
    border: 1px solid var(--pc-color-border-default);
    border-radius: var(--pc-radius-xl);
    padding: 48px;
    box-shadow: var(--pc-shadow-md);
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    align-items: center;
    gap: 24px;
    position: relative;
  }

  .arch-node {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 24px 16px;
    background: var(--pc-color-bg-subtle);
    border-radius: var(--pc-radius-lg);
    text-align: center;
    color: var(--pc-color-text-primary);
    font-weight: var(--pc-weight-medium);
    font-size: var(--pc-text-body-sm);
    min-height: 120px;
    justify-content: center;
  }

  .arch-server {
    background: var(--pc-color-accent-subtle);
    color: var(--pc-color-accent-default);
    font-weight: var(--pc-weight-semibold);
  }

  .arch-sub {
    font-size: var(--pc-text-caption);
    color: var(--pc-color-text-muted);
    font-family: var(--pc-font-mono);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .arch-arrow {
    color: var(--pc-color-text-muted);
    font-size: 24px;
  }

  .arch-external {
    position: absolute;
    bottom: -28px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--pc-color-success-subtle);
    color: var(--pc-color-success);
    padding: 6px 16px;
    border-radius: var(--pc-radius-pill);
    font-size: var(--pc-text-caption);
    font-weight: var(--pc-weight-semibold);
    border: 1px solid color-mix(in srgb, var(--pc-color-success) 30%, transparent);
  }

  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .pillar-card {
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .pillar-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    background: var(--pc-color-accent-subtle);
    border-radius: var(--pc-radius-xl);
    color: var(--pc-color-accent-default);
    margin-bottom: 8px;
  }

  .pillar-title {
    font-size: var(--pc-text-section-h3);
    font-weight: var(--pc-weight-semibold);
    color: var(--pc-color-text-primary);
    letter-spacing: -0.02em;
  }

  .pillar-description {
    color: var(--pc-color-text-secondary);
    font-size: var(--pc-text-body);
    line-height: var(--pc-line-relaxed);
  }

  @media (max-width: 960px) {
    .arch-diagram {
      grid-template-columns: 1fr;
      gap: 16px;
      padding: 32px 24px;
    }
    .arch-arrow {
      transform: rotate(90deg);
    }
    .pillars-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

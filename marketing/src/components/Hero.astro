---
import type { PageContent } from '../content/types';
import PhosphorIcon from './PhosphorIcon.astro';

interface Props {
  content: PageContent;
}

const { content } = Astro.props;
const hero = content.hero;
const h1Lines = hero.h1.split('\n');

const isZh = content.locale === 'zh';
const prompt = isZh ? '$' : '$';
const commentDelim = '#';

const codeLines: Array<{ kind: 'prompt' | 'comment' | 'output'; text: string }> = isZh
  ? [
      { kind: 'prompt', text: `git clone github.com/iannil/pinconsole` },
      { kind: 'prompt', text: `cd pinconsole && cp .env.example .env` },
      { kind: 'prompt', text: `make docker-up build-frontend build` },
      { kind: 'comment', text: `${commentDelim} 访客落地页 → http://localhost:8080/` },
      { kind: 'comment', text: `${commentDelim} 运营后台   → http://localhost:8080/admin` },
    ]
  : [
      { kind: 'prompt', text: `git clone github.com/iannil/pinconsole` },
      { kind: 'prompt', text: `cd pinconsole && cp .env.example .env` },
      { kind: 'prompt', text: `make docker-up build-frontend build` },
      { kind: 'comment', text: `${commentDelim} visitor landing → http://localhost:8080/` },
      { kind: 'comment', text: `${commentDelim} operator admin  → http://localhost:8080/admin` },
    ];
---

<section class="hero">
  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="hero-eyebrow">{hero.eyebrow}</p>

      <h1 class="hero-title">
        {h1Lines.map((line) => (
          <span class="hero-title-line">{line}</span>
        ))}
      </h1>

      <p class="lead hero-lead">{hero.h2}</p>

      <div class="hero-cta">
        <a href={hero.cta.primary.href} class="btn btn-primary">
          {hero.cta.primary.label}
          <PhosphorIcon name="arrow-right" size={14} weight="bold" />
        </a>
        {hero.cta.secondary && (
          <a href={hero.cta.secondary.href} class="btn btn-secondary">
            {hero.cta.secondary.label}
          </a>
        )}
        {hero.cta.tertiary && (
          <a href={hero.cta.tertiary.href} class="btn btn-ghost" target="_blank" rel="noopener">
            <PhosphorIcon name="github" size={14} />
            {hero.cta.tertiary.label}
          </a>
        )}
      </div>
    </div>

    <div class="hero-code-wrap">
      <div class="code-window" aria-label={isZh ? '自部署命令' : 'self-host commands'}>
        <header class="code-window-header">
          <span class="code-window-dot" aria-hidden="true"></span>
          <span class="code-window-title">~/pinconsole</span>
          <span class="code-window-meta">bash · 5 min</span>
        </header>
        <pre class="code-window-body"><code>{codeLines.map((line) => (
          <span class={`code-line code-${line.kind}`}>
            {line.kind === 'prompt' && <span class="code-prompt">{prompt}</span>}
            <span class="code-text">{line.text}</span>
          </span>
        ))}</code></pre>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: 96px;
    padding-bottom: 96px;
    position: relative;
    border-bottom: 1px solid var(--pc-color-border-default);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
  }

  .hero-eyebrow {
    font-family: var(--pc-font-mono);
    font-size: var(--pc-text-micro);
    font-weight: var(--pc-weight-medium);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--pc-color-text-accent);
    padding: 6px 10px;
    border: 1px solid var(--pc-color-border-strong);
    border-radius: var(--pc-radius-sm);
    background: var(--pc-color-accent-subtle);
  }

  .hero-title {
    font-family: var(--pc-font-sans);
    font-size: var(--pc-text-manifesto);
    font-weight: var(--pc-weight-semibold);
    line-height: var(--pc-line-tight);
    letter-spacing: -0.03em;
    color: var(--pc-color-text-primary);
    margin: 0;
  }

  :lang(zh) .hero-title,
  :lang(zh-CN) .hero-title {
    font-family: var(--pc-font-sans-zh);
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .hero-title-line {
    display: block;
  }

  .hero-title-line:last-child {
    color: var(--pc-color-accent-default);
  }

  .hero-lead {
    font-size: var(--pc-text-lead);
    line-height: var(--pc-line-relaxed);
    color: var(--pc-color-text-secondary);
    max-width: 56ch;
    font-weight: var(--pc-weight-regular);
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    margin-top: 8px;
  }

  /* ===== Code window — Linear/Vercel style ===== */
  .hero-code-wrap {
    position: relative;
  }

  .code-window {
    background: var(--pc-color-bg-surface);
    border: 1px solid var(--pc-color-border-strong);
    border-radius: var(--pc-radius-lg);
    overflow: hidden;
    box-shadow: var(--pc-shadow-lg);
  }

  .code-window-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    border-bottom: 1px solid var(--pc-color-border-default);
    background: var(--pc-color-bg-elevated);
  }

  .code-window-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--pc-color-accent-default);
    box-shadow: 0 0 6px var(--pc-color-accent-default);
  }

  .code-window-title {
    font-family: var(--pc-font-mono);
    font-size: var(--pc-text-micro);
    color: var(--pc-color-text-muted);
    letter-spacing: 0.04em;
  }

  .code-window-meta {
    margin-left: auto;
    font-family: var(--pc-font-mono);
    font-size: 10px;
    color: var(--pc-color-text-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .code-window-body {
    margin: 0;
    padding: 20px 22px;
    background: transparent;
    border: 0;
    border-radius: 0;
    font-family: var(--pc-font-mono);
    font-size: 13px;
    line-height: 1.9;
    color: var(--pc-color-text-primary);
    overflow-x: auto;
  }

  .code-line {
    display: block;
    min-height: 1.9em;
  }

  .code-prompt {
    color: var(--pc-color-accent-default);
    margin-right: 10px;
    font-weight: var(--pc-weight-semibold);
    user-select: none;
  }

  .code-comment .code-text {
    color: var(--pc-color-text-muted);
  }

  .code-prompt .code-text {
    color: var(--pc-color-text-primary);
  }

  @media (max-width: 960px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .hero {
      padding-top: 64px;
      padding-bottom: 64px;
    }
  }

  @media (max-width: 600px) {
    .hero-title {
      font-size: clamp(38px, 11vw, 56px);
    }
    .code-window-body {
      font-size: 12px;
      padding: 16px;
    }
  }
</style>

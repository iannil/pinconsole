---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import Hero from '../components/Hero.astro';
import WhyPinconsole from '../components/WhyPinconsole.astro';
import Features from '../components/Features.astro';
import Roadmap from '../components/Roadmap.astro';
import FAQ from '../components/FAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';
import { zh as content } from '../content/zh';
---

<MarketingLayout content={content}>
  <Hero content={content} />
  <WhyPinconsole content={content} />
  <Features content={content} />
  <Roadmap content={content} />
  <FAQ content={content} />
  <FinalCTA content={content} />
</MarketingLayout>

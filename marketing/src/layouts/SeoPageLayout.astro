---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { SeoPageContent } from '../content/pages/types';

interface Props {
  content: SeoPageContent;
}

const { content } = Astro.props;
const locale = content.locale;
const siteUrl = 'https://pinconsole.com';

// Determine canonical path from Astro request URL
const canonicalUrl = Astro.url.href;

// Derive page-specific hreflang from current URL
const urlPath = new URL(canonicalUrl).pathname;
const isEnPage = urlPath.startsWith('/en/');
const basePath = isEnPage ? urlPath.replace('/en', '') : urlPath;
const zhHreflang = `${siteUrl}${basePath}`;
const enHreflang = `${siteUrl}/en${basePath}`;

const ogImageUrl = `${siteUrl}/og-image.webp`;
const cfAnalyticsToken = import.meta.env.CF_WEB_ANALYTICS_TOKEN || '';
const baiduVerificationToken = '';
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID || '';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      name: 'PinConsole',
      url: siteUrl,
      logo: `${siteUrl}/favicon.svg`,
      description: content.meta.description,
    },
    {
      '@type': 'WebSite',
      name: 'PinConsole',
      url: siteUrl,
      inLanguage: locale === 'zh' ? 'zh-CN' : 'en-US',
      description: content.meta.description,
    },
    {
      '@type': 'SoftwareApplication',
      name: 'PinConsole',
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Linux, macOS, Windows (Docker)',
      description: 'Open source ToB real-time visitor monitoring + operator interaction + session replay platform. AGPL-3.0, self-hosted.',
      offers: {
        '@type': 'Offer',
        price: '0',
        priceCurrency: 'USD',
        priceValidUntil: '2030-12-31',
      },
      license: 'https://github.com/iannil/pinconsole/blob/master/LICENSE',
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'PinConsole', item: siteUrl },
        { '@type': 'ListItem', position: 2, name: content.meta.title, item: canonicalUrl },
      ],
    },
    {
      '@type': 'WebPage',
      name: content.meta.title,
      description: content.meta.description,
      url: canonicalUrl,
      inLanguage: locale === 'zh' ? 'zh-CN' : 'en-US',
    },
  ],
};
---

<!doctype html>
<html lang={content.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{content.meta.title}</title>
    <meta name="description" content={content.meta.description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={content.meta.ogTitle} />
    <meta property="og:description" content={content.meta.ogDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={locale === 'zh' ? 'zh_CN' : 'en_US'} />
    <meta property="og:site_name" content="PinConsole" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={content.meta.ogTitle} />
    <meta name="twitter:description" content={content.meta.ogDescription} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="alternate" hreflang="zh-CN" href={zhHreflang} />
    <link rel="alternate" hreflang="en-US" href={enHreflang} />
    <link rel="alternate" hreflang="x-default" href={zhHreflang} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/favicon.svg" color="#10B981" />

    {baiduVerificationToken && (
      <meta name="baidu-site-verification" content={baiduVerificationToken} />
    )}

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- GA4 Consent Mode v2 — default denied -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('consent', 'default', {
        ad_storage: 'denied',
        analytics_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        wait_for_update: 500,
      });
    </script>

    {gaId && (
      <Fragment>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`} />
        <script is:inline define:vars={{ gaId }}>
          gtag('js', new Date());
          gtag('config', gaId, { anonymize_ip: true });
        </script>
      </Fragment>
    )}
  </head>
  <body>
    {locale === 'zh' ? (
      <Header content={{
        locale: 'zh',
        htmlLang: 'zh-CN',
        meta: { title: '', description: '', ogTitle: '', ogDescription: '' },
        nav: {
          links: [
            { label: '首页', href: '/' },
            { label: 'GitHub', href: 'https://github.com/iannil/pinconsole' },
          ],
          cta: '预约咨询',
          localeSwitch: { label: 'EN', href: '/en' },
        },
        hero: { eyebrow: '', h1: '', h2: '', cta: { primary: { label: '', href: '' } } },
        features: { eyebrow: '', title: '', subtitle: '', items: [] },
        dataSovereignty: { eyebrow: '', title: '', subtitle: '', pillars: [], architectureAlt: '' },
        selfHost: { eyebrow: '', title: '', subtitle: '', code: '', docsLink: { label: '', href: '' } },
        roadmap: { eyebrow: '', title: '', subtitle: '', columns: [] },
        faq: { eyebrow: '', title: '', subtitle: '', items: [] },
        finalCTA: {
          eyebrow: '', title: '', subtitle: '',
          form: {
            nameLabel: '', namePlaceholder: '', companyLabel: '', companyPlaceholder: '',
            contactLabel: '', contactPlaceholder: '', purposeLabel: '',
            purposes: [], messageLabel: '', messagePlaceholder: '',
            submitLabel: '', privacyNote: '', successMessage: '', errorMessage: '',
          },
        },
        footer: { tagline: '', columns: [], license: '', sourceNote: '' },
      }} />
    ) : (
      <Header content={{
        locale: 'en',
        htmlLang: 'en-US',
        meta: { title: '', description: '', ogTitle: '', ogDescription: '' },
        nav: {
          links: [
            { label: 'Home', href: '/en' },
            { label: 'GitHub', href: 'https://github.com/iannil/pinconsole' },
          ],
          cta: 'Request consultation',
          localeSwitch: { label: '中', href: '/' },
        },
        hero: { eyebrow: '', h1: '', h2: '', cta: { primary: { label: '', href: '' } } },
        features: { eyebrow: '', title: '', subtitle: '', items: [] },
        dataSovereignty: { eyebrow: '', title: '', subtitle: '', pillars: [], architectureAlt: '' },
        selfHost: { eyebrow: '', title: '', subtitle: '', code: '', docsLink: { label: '', href: '' } },
        roadmap: { eyebrow: '', title: '', subtitle: '', columns: [] },
        faq: { eyebrow: '', title: '', subtitle: '', items: [] },
        finalCTA: {
          eyebrow: '', title: '', subtitle: '',
          form: {
            nameLabel: '', namePlaceholder: '', companyLabel: '', companyPlaceholder: '',
            contactLabel: '', contactPlaceholder: '', purposeLabel: '',
            purposes: [], messageLabel: '', messagePlaceholder: '',
            submitLabel: '', privacyNote: '', successMessage: '', errorMessage: '',
          },
        },
        footer: { tagline: '', columns: [], license: '', sourceNote: '' },
      }} />
    )}

    <main>
      <!-- Hero -->
      <section class="seo-hero">
        <div class="container">
          <h1>{content.hero.h1}</h1>
          <p class="seo-subtitle">{content.hero.subtitle}</p>
        </div>
      </section>

      <!-- Comparison table -->
      {content.comparison.rows.length > 0 && (
        <section class="seo-comparison">
          <div class="container">
            <div class="comparison-scroll">
              <table class="comparison-table">
                <thead>
                  <tr>
                    <th></th>
                    <th class="col-pinconsole">PinConsole</th>
                    <th class="col-competitor">{locale === 'zh' ? '竞品' : 'Competitor'}</th>
                  </tr>
                </thead>
                <tbody>
                  {content.comparison.rows.map((row) => (
                    <tr class:list={{ 'highlight-row': row.isHighlight }}>
                      <td class="comparison-label">{row.label}</td>
                      <td class="comparison-value pinconsole">{row.pinconsole}</td>
                      <td class="comparison-value">{row.competitor}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </section>
      )}

      <!-- Content sections -->
      <section class="seo-content">
        <div class="container container-narrow">
          {content.content.sections.map((section) => (
            <article class="seo-section">
              <h2>{section.heading}</h2>
              <p>{section.body}</p>
            </article>
          ))}
        </div>
      </section>

      <!-- FAQ -->
      {content.faq.items.length > 0 && (
        <section class="seo-faq">
          <div class="container container-narrow">
            <h2>{locale === 'zh' ? '常见问题' : 'Frequently Asked Questions'}</h2>
            <div class="faq-list">
              {content.faq.items.map((item) => (
                <details class="faq-item">
                  <summary>{item.question}</summary>
                  <p>{item.answer}</p>
                </details>
              ))}
            </div>
          </div>
          <!-- FAQPage structured data -->
          <script type="application/ld+json" set:html={JSON.stringify({
            '@context': 'https://schema.org',
            '@type': 'FAQPage',
            mainEntity: content.faq.items.map((item) => ({
              '@type': 'Question',
              name: item.question,
              acceptedAnswer: { '@type': 'Answer', text: item.answer },
            })),
          })} />
        </section>
      )}

      <!-- CTA -->
      <section class="seo-cta">
        <div class="container container-narrow">
          <h2>{content.cta.title}</h2>
          <p>{content.cta.subtitle}</p>
          <div class="cta-buttons">
            <a href={content.cta.primary.href} class="btn-primary">{content.cta.primary.label}</a>
            {content.cta.secondary && (
              <a href={content.cta.secondary.href} class="btn-secondary">{content.cta.secondary.label}</a>
            )}
          </div>
        </div>
      </section>
    </main>

    <Footer content={{
      locale: locale,
      htmlLang: locale === 'zh' ? 'zh-CN' : 'en-US',
      meta: { title: '', description: '', ogTitle: '', ogDescription: '' },
      nav: { links: [], cta: '', localeSwitch: { label: '', href: '' } },
      hero: { eyebrow: '', h1: '', h2: '', cta: { primary: { label: '', href: '' } } },
      features: { eyebrow: '', title: '', subtitle: '', items: [] },
      dataSovereignty: { eyebrow: '', title: '', subtitle: '', pillars: [], architectureAlt: '' },
      selfHost: { eyebrow: '', title: '', subtitle: '', code: '', docsLink: { label: '', href: '' } },
      roadmap: { eyebrow: '', title: '', subtitle: '', columns: [] },
      faq: { eyebrow: '', title: '', subtitle: '', items: [] },
      finalCTA: {
        eyebrow: '', title: '', subtitle: '',
        form: {
          nameLabel: '', namePlaceholder: '', companyLabel: '', companyPlaceholder: '',
          contactLabel: '', contactPlaceholder: '', purposeLabel: '',
          purposes: [], messageLabel: '', messagePlaceholder: '',
          submitLabel: '', privacyNote: '', successMessage: '', errorMessage: '',
        },
      },
      footer: {
        tagline: '',
        columns: [
          {
            title: locale === 'zh' ? '产品' : 'Product',
            links: [
              { label: locale === 'zh' ? '首页' : 'Home', href: locale === 'zh' ? '/' : '/en' },
            ],
          },
        ],
        license: 'AGPL-3.0-or-later',
        sourceNote: '© 2026 PinConsole. Built with Calm Crafted design system.',
      },
    }} />

    <!-- Cloudflare Web Analytics -->
    {cfAnalyticsToken && (
      <script defer src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${cfAnalyticsToken}"`} />
    )}
  </body>
</html>

<style is:global>
  /* SEO page styles */
  .seo-hero {
    padding: 80px 0 48px;
    background: var(--pc-color-bg-canvas);
    border-bottom: 1px solid var(--pc-color-border-default);
  }
  .seo-hero h1 {
    font-size: var(--pc-hero-h1, clamp(32px, 5vw, 56px));
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0 0 16px;
    color: var(--pc-color-text-primary);
  }
  .seo-subtitle {
    font-size: var(--pc-text-body-lg, 18px);
    line-height: 1.6;
    color: var(--pc-color-text-secondary);
    max-width: 720px;
  }

  /* Comparison table */
  .seo-comparison {
    padding: 48px 0;
    background: var(--pc-color-bg-surface);
    border-bottom: 1px solid var(--pc-color-border-default);
  }
  .comparison-scroll {
    overflow-x: auto;
  }
  .comparison-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--pc-text-body-sm, 14px);
  }
  .comparison-table th,
  .comparison-table td {
    padding: 12px 16px;
    text-align: left;
    border-bottom: 1px solid var(--pc-color-border-default);
  }
  .comparison-table thead th {
    font-weight: 600;
    color: var(--pc-color-text-primary);
    background: var(--pc-color-bg-elevated);
  }
  .col-pinconsole { color: var(--pc-color-accent-default); }
  .col-competitor { color: var(--pc-color-text-muted); }
  .comparison-label { font-weight: 500; color: var(--pc-color-text-primary); white-space: nowrap; }
  .comparison-value { color: var(--pc-color-text-secondary); }
  .comparison-value.pinconsole { color: var(--pc-color-accent-default); }
  .highlight-row { background: var(--pc-color-accent-subtle); }

  /* Content sections */
  .seo-content {
    padding: 48px 0;
    background: var(--pc-color-bg-canvas);
    border-bottom: 1px solid var(--pc-color-border-default);
  }
  .seo-section {
    margin-bottom: 40px;
  }
  .seo-section:last-child { margin-bottom: 0; }
  .seo-section h2 {
    font-size: var(--pc-text-headline, 24px);
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.3;
    margin: 0 0 12px;
    color: var(--pc-color-text-primary);
  }
  .seo-section p {
    font-size: var(--pc-text-body, 16px);
    line-height: 1.7;
    color: var(--pc-color-text-secondary);
    margin: 0;
  }

  /* FAQ */
  .seo-faq {
    padding: 48px 0;
    background: var(--pc-color-bg-surface);
    border-bottom: 1px solid var(--pc-color-border-default);
  }
  .seo-faq h2 {
    font-size: var(--pc-text-headline, 24px);
    font-weight: 600;
    margin: 0 0 24px;
    color: var(--pc-color-text-primary);
  }
  .faq-list { display: flex; flex-direction: column; gap: 8px; }
  .faq-item {
    border: 1px solid var(--pc-color-border-default);
    border-radius: var(--pc-radius-sm, 6px);
    padding: 16px 20px;
    background: var(--pc-color-bg-canvas);
  }
  .faq-item summary {
    font-weight: 500;
    cursor: pointer;
    color: var(--pc-color-text-primary);
  }
  .faq-item p {
    margin: 12px 0 0;
    font-size: var(--pc-text-body-sm, 14px);
    line-height: 1.6;
    color: var(--pc-color-text-secondary);
  }

  /* CTA */
  .seo-cta {
    padding: 64px 0;
    background: var(--pc-color-bg-canvas);
    text-align: center;
    border-bottom: 1px solid var(--pc-color-border-default);
  }
  .seo-cta h2 {
    font-size: var(--pc-text-headline, 24px);
    font-weight: 700;
    margin: 0 0 12px;
    color: var(--pc-color-text-primary);
  }
  .seo-cta p {
    font-size: var(--pc-text-body, 16px);
    color: var(--pc-color-text-secondary);
    margin: 0 0 24px;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }
  .cta-buttons {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn-primary, .btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 10px 24px;
    border-radius: var(--pc-radius-sm, 6px);
    font-size: var(--pc-text-body-sm, 14px);
    font-weight: 500;
    text-decoration: none;
    transition: all var(--pc-duration-fast, 150ms);
  }
  .btn-primary {
    background: var(--pc-color-accent-default);
    color: var(--pc-color-text-inverse, #fff);
    border: 1px solid var(--pc-color-accent-default);
  }
  .btn-primary:hover {
    background: var(--pc-color-accent-hover);
    border-color: var(--pc-color-accent-hover);
  }
  .btn-secondary {
    background: transparent;
    color: var(--pc-color-text-primary);
    border: 1px solid var(--pc-color-border-strong);
  }
  .btn-secondary:hover {
    border-color: var(--pc-color-accent-default);
    color: var(--pc-color-accent-default);
  }

  .container-narrow {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 24px;
  }
</style>

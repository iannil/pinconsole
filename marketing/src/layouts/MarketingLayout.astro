---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { PageContent } from '../content/types';

interface Props {
  content: PageContent;
}

const { content } = Astro.props;
const locale = content.locale;
const siteUrl = 'https://pinconsole.com';
const canonicalPath = locale === 'zh' ? '/' : '/en/';
const canonicalUrl = `${siteUrl}${canonicalPath}`;
const ogImageUrl = `${siteUrl}/og-image.png`;
const cfAnalyticsToken = 'PASTE_CF_WEB_ANALYTICS_TOKEN'; // overridden by env in production

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      name: 'PinConsole',
      url: siteUrl,
      logo: `${siteUrl}/favicon.svg`,
      description: content.meta.description,
    },
    {
      '@type': 'WebSite',
      name: 'PinConsole',
      url: siteUrl,
      inLanguage: locale === 'zh' ? 'zh-CN' : 'en-US',
      description: content.meta.description,
    },
  ],
};
---

<!doctype html>
<html lang={content.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{content.meta.title}</title>
    <meta name="description" content={content.meta.description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={content.meta.ogTitle} />
    <meta property="og:description" content={content.meta.ogDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={locale === 'zh' ? 'zh_CN' : 'en_US'} />
    <meta property="og:site_name" content="PinConsole" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={content.meta.ogTitle} />
    <meta name="twitter:description" content={content.meta.ogDescription} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="alternate" hreflang="zh-CN" href="/" />
    <link rel="alternate" hreflang="en-US" href="/en" />
    <link rel="alternate" hreflang="x-default" href="/" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/favicon.svg" color="#10B981" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Cloudflare Turnstile widget script (loaded on all pages; rendered only on form mount) -->
    <script defer src="https://challenges.cloudflare.com/turnstile/v0/api.js" async />

    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header content={content} />
    <main id="main">
      <slot />
    </main>
    <Footer content={content} />

    <!-- Cloudflare Web Analytics — privacy-friendly, no cookies -->
    {cfAnalyticsToken && cfAnalyticsToken !== 'PASTE_CF_WEB_ANALYTICS_TOKEN' && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${cfAnalyticsToken}"`}
      />
    )}

    <script>
      // Reveal on scroll — staggered manifesto entrance with --reveal-delay
      const reveals = document.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window && reveals.length > 0) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                (entry.target as HTMLElement).classList.add('is-visible');
                io.unobserve(entry.target);
              }
            }
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.05 }
        );
        reveals.forEach((el) => io.observe(el));
      } else {
        reveals.forEach((el) => el.classList.add('is-visible'));
      }
    </script>
    <style>
      .skip-link {
        position: absolute;
        top: -40px;
        left: 8px;
        z-index: var(--pc-z-overlay);
        padding: 8px 16px;
        background: var(--pc-color-bg-surface);
        color: var(--pc-color-text-primary);
        border-radius: var(--pc-radius-sm);
        transition: top var(--pc-duration-fast) var(--pc-easing);
      }
      .skip-link:focus {
        top: 8px;
      }
    </style>
  </body>
</html>

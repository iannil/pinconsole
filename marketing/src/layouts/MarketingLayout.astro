---
import '../styles/global.css';
import fontsCssUrl from '../styles/fonts.css?url';
import { APP_VERSION } from '../constants';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Footer from '../components/Footer.astro';
import type { PageContent } from '../content/types';

interface Props {
  content: PageContent;
}

const { content } = Astro.props;
const locale = content.locale;
const siteUrl = 'https://pinconsole.com';
const canonicalPath = locale === 'zh' ? '/' : '/en/';
const canonicalUrl = `${siteUrl}${canonicalPath}`;
const ogImageUrl = `${siteUrl}/og-image.webp`;
const cfAnalyticsToken = import.meta.env.CF_WEB_ANALYTICS_TOKEN || '';
const baiduVerificationToken = '';
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID || '';

const softwareAppDesc =
  'Open source ToB real-time visitor monitoring + operator interaction + session replay platform. AGPL-3.0, self-hosted, data never leaves your infrastructure.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      name: 'PinConsole',
      url: siteUrl,
      logo: `${siteUrl}/favicon.svg`,
      description: content.meta.description,
    },
    {
      '@type': 'WebSite',
      name: 'PinConsole',
      url: siteUrl,
      inLanguage: locale === 'zh' ? 'zh-CN' : 'en-US',
      description: content.meta.description,
    },
    {
      '@type': 'SoftwareApplication',
      name: 'PinConsole',
      applicationCategory: 'BusinessApplication',
      applicationSubCategory: 'CustomerAnalytics, WebAnalytics, SessionReplay',
      operatingSystem: 'Linux, macOS, Windows (Docker)',
      description: softwareAppDesc,
      image: `${siteUrl}/og-image.webp`,
      screenshot: [
        `${siteUrl}/screenshots/dashboard.webp`,
        `${siteUrl}/screenshots/replay.webp`,
        `${siteUrl}/screenshots/cobrowse.webp`,
      ],
      featureList: 'Session replay, Co-browsing, Real-time visitor monitoring, Popup chat, Anti-bot protection, Self-hosted, Open source',
      softwareVersion: APP_VERSION,
      offers: {
        '@type': 'Offer',
        price: '0',
        priceCurrency: 'USD',
        priceValidUntil: '2030-12-31',
      },
      license: 'https://github.com/iannil/pinconsole/blob/master/LICENSE',
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'PinConsole',
          item: canonicalUrl,
        },
      ],
    },
    {
      '@type': 'WebPage',
      name: content.meta.title,
      description: content.meta.description,
      url: canonicalUrl,
      inLanguage: locale === 'zh' ? 'zh-CN' : 'en-US',
    },
  ],
};
---

<!doctype html>
<html lang={content.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{content.meta.title}</title>
    <meta name="description" content={content.meta.description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={content.meta.ogTitle} />
    <meta property="og:description" content={content.meta.ogDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={locale === 'zh' ? 'zh_CN' : 'en_US'} />
    <meta property="og:site_name" content="PinConsole" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={content.meta.ogTitle} />
    <meta name="twitter:description" content={content.meta.ogDescription} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="alternate" hreflang="zh-CN" href="/" />
    <link rel="alternate" hreflang="en-US" href="/en" />
    <link rel="alternate" hreflang="x-default" href="/" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/favicon.svg" color="#10B981" />

    <!-- Self-hosted fonts (loaded as external module via Vite dev server) -->
    <link rel="stylesheet" href={fontsCssUrl} />

    <!-- Baidu site verification (conditional — leave blank if not using Baidu Webmaster Tools) -->
    {baiduVerificationToken && (
      <meta name="baidu-site-verification" content={baiduVerificationToken} />
    )}

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <slot name="head" />

    <!-- GA4 Consent Mode v2 — default denied (no cookies; cookieless ping for modeling) -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('consent', 'default', {
        ad_storage: 'denied',
        analytics_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        wait_for_update: 500,
      });
    </script>

    <!-- GA4 gtag.js — only renders when measurement ID is configured -->
    {gaId && (
      <Fragment>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`} />
        <script is:inline define:vars={{ gaId }}>
          gtag('js', new Date());
          gtag('config', gaId, { anonymize_ip: true });
        </script>
      </Fragment>
    )}
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header content={content} />
    <main id="main">
      <slot />
    </main>
    <Footer content={content} />

    <!-- Cloudflare Web Analytics — privacy-friendly, no cookies -->
    {cfAnalyticsToken && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${cfAnalyticsToken}"`}
      />
    )}

    <script>
      // Reveal on scroll — staggered manifesto entrance with --reveal-delay
      const reveals = document.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window && reveals.length > 0) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                (entry.target as HTMLElement).classList.add('is-visible');
                io.unobserve(entry.target);
              }
            }
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.05 }
        );
        reveals.forEach((el) => io.observe(el));
      } else {
        reveals.forEach((el) => el.classList.add('is-visible'));
      }
    </script>
    <style>
      .skip-link {
        position: absolute;
        top: -40px;
        left: 8px;
        z-index: var(--pc-z-overlay);
        padding: 8px 16px;
        background: var(--pc-color-bg-surface);
        color: var(--pc-color-text-primary);
        border-radius: var(--pc-radius-sm);
        transition: top var(--pc-duration-fast) var(--pc-easing);
      }
      .skip-link:focus {
        top: 8px;
      }
    </style>
  </body>
</html>

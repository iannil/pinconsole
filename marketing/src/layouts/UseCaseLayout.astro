---
import '../styles/global.css';
import fontsCssUrl from '../styles/fonts.css?url';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { zhContentHeader, enContentHeader } from '../content/nav-shared';

export interface UseCaseContent {
  locale: 'zh' | 'en';
  htmlLang: string;
  meta: { title: string; description: string; ogTitle: string; ogDescription: string };
  hero: { h1: string; subtitle: string };
  sections: { heading: string; body: string }[];
  cta: { title: string; subtitle: string; primary: { label: string; href: string }; secondary?: { label: string; href: string } };
}

interface Props {
  content: UseCaseContent;
  path: string;
}

const { content, path } = Astro.props;
const locale = content.locale;
const siteUrl = 'https://pinconsole.com';
const canonicalUrl = `${siteUrl}${path}`;
const ogImageUrl = `${siteUrl}/og-image.webp`;
const cfAnalyticsToken = import.meta.env.CF_WEB_ANALYTICS_TOKEN || '';
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID || '';

const isEnPage = path.startsWith('/en/');
const basePath = isEnPage ? path.replace('/en', '') : path;
const zhHreflang = `${siteUrl}${basePath}`;
const enHreflang = `${siteUrl}/en${basePath}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'Organization', name: 'PinConsole', url: siteUrl, logo: `${siteUrl}/favicon.svg`, description: content.meta.description },
    { '@type': 'WebSite', name: 'PinConsole', url: siteUrl, inLanguage: locale === 'zh' ? 'zh-CN' : 'en-US', description: content.meta.description },
    { '@type': 'BreadcrumbList', itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'PinConsole', item: siteUrl },
      { '@type': 'ListItem', position: 2, name: 'Use Cases', item: locale === 'zh' ? `${siteUrl}/use-cases/` : `${siteUrl}/en/use-cases/` },
      { '@type': 'ListItem', position: 3, name: content.meta.title, item: canonicalUrl },
    ]},
    { '@type': 'WebPage', name: content.meta.title, description: content.meta.description, url: canonicalUrl, inLanguage: locale === 'zh' ? 'zh-CN' : 'en-US' },
  ],
};
---

<!doctype html>
<html lang={content.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{content.meta.title}</title>
    <meta name="description" content={content.meta.description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={content.meta.ogTitle} />
    <meta property="og:description" content={content.meta.ogDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={locale === 'zh' ? 'zh_CN' : 'en_US'} />
    <meta property="og:site_name" content="PinConsole" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={content.meta.ogTitle} />
    <meta name="twitter:description" content={content.meta.ogDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="alternate" hreflang="zh-CN" href={zhHreflang} />
    <link rel="alternate" hreflang="en-US" href={enHreflang} />
    <link rel="alternate" hreflang="x-default" href={zhHreflang} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/favicon.svg" color="#10B981" />
    <link rel="stylesheet" href={fontsCssUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script is:inline>window.dataLayer = window.dataLayer || []; function gtag(){dataLayer.push(arguments);} gtag('consent','default',{ad_storage:'denied',analytics_storage:'denied',ad_user_data:'denied',ad_personalization:'denied',wait_for_update:500});</script>
    {gaId && <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`} />}
    {gaId && <script is:inline define:vars={{ gaId }}>
      gtag('js', new Date());
      gtag('config', gaId, { anonymize_ip: true });
    </script>}
  </head>
  <body>
    <Header content={locale === 'zh' ? zhContentHeader : enContentHeader} />

    <main>
      <section class="page-hero">
        <div class="container container-narrow">
          <h1>{content.hero.h1}</h1>
          <p class="page-subtitle">{content.hero.subtitle}</p>
        </div>
      </section>

      <section class="page-body">
        <div class="container container-narrow">
          {content.sections.map((section) => (
            <article class="content-block">
              <h2>{section.heading}</h2>
              {section.body.split('\n\n').map((para) => <p>{para.trim()}</p>)}
            </article>
          ))}
        </div>
      </section>

      <section class="page-cta">
        <div class="container container-narrow">
          <h2>{content.cta.title}</h2>
          <p>{content.cta.subtitle}</p>
          <div class="cta-buttons">
            <a href={content.cta.primary.href} class="btn-primary">{content.cta.primary.label}</a>
            {content.cta.secondary && <a href={content.cta.secondary.href} class="btn-secondary">{content.cta.secondary.label}</a>}
          </div>
        </div>
      </section>
    </main>

    <Footer content={{
      locale: locale, htmlLang: content.htmlLang,
      meta: { title: '', description: '', ogTitle: '', ogDescription: '' },
      nav: { links: [], cta: '', localeSwitch: { label: '', href: '' } },
      hero: { eyebrow: '', h1: '', h2: '', cta: { primary: { label: '', href: '' } } },
      features: { eyebrow: '', title: '', subtitle: '', items: [] },
      dataSovereignty: { eyebrow: '', title: '', subtitle: '', pillars: [], architectureAlt: '' },
      selfHost: { eyebrow: '', title: '', subtitle: '', code: '', docsLink: { label: '', href: '' } },
      roadmap: { eyebrow: '', title: '', subtitle: '', columns: [] },
      faq: { eyebrow: '', title: '', subtitle: '', items: [] },
      finalCTA: { eyebrow: '', title: '', subtitle: '', form: { nameLabel: '', namePlaceholder: '', companyLabel: '', companyPlaceholder: '', contactLabel: '', contactPlaceholder: '', purposeLabel: '', purposes: [], messageLabel: '', messagePlaceholder: '', submitLabel: '', privacyNote: '', successMessage: '', errorMessage: '' } },
      footer: { tagline: '', columns: [{ title: locale === 'zh' ? '导航' : 'Navigation', links: [
        { label: locale === 'zh' ? '首页' : 'Home', href: locale === 'zh' ? '/' : '/en' },
        { label: 'Blog', href: locale === 'zh' ? '/blog/' : '/en/blog/' },
        { label: locale === 'zh' ? '关于' : 'About', href: locale === 'zh' ? '/about/' : '/en/about/' },
      ]}], license: 'AGPL-3.0-or-later', sourceNote: '© 2026 PinConsole.' },
    }} />

    {cfAnalyticsToken && <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon={`{"token": "${cfAnalyticsToken}"`} />}

    <style is:global>
      .page-hero { padding: 80px 0 48px; background: var(--pc-color-bg-canvas); border-bottom: 1px solid var(--pc-color-border-default); }
      .page-hero h1 { font-size: var(--pc-hero-h1, clamp(28px, 4vw, 48px)); font-weight: 700; letter-spacing: -0.02em; line-height: 1.15; margin: 0 0 16px; color: var(--pc-color-text-primary); }
      .page-subtitle { font-size: var(--pc-text-body-lg, 18px); line-height: 1.6; color: var(--pc-color-text-secondary); max-width: 720px; margin: 0; }
      .page-body { padding: 48px 0; background: var(--pc-color-bg-canvas); border-bottom: 1px solid var(--pc-color-border-default); }
      .content-block { margin-bottom: 40px; }
      .content-block:last-child { margin-bottom: 0; }
      .content-block h2 { font-size: var(--pc-text-headline, 24px); font-weight: 600; letter-spacing: -0.01em; line-height: 1.3; margin: 0 0 16px; color: var(--pc-color-text-primary); }
      .content-block p { font-size: var(--pc-text-body, 16px); line-height: 1.8; color: var(--pc-color-text-secondary); margin: 0 0 16px; white-space: pre-wrap; }
      .page-cta { padding: 64px 0; background: var(--pc-color-bg-surface); text-align: center; border-bottom: 1px solid var(--pc-color-border-default); }
      .page-cta h2 { font-size: var(--pc-text-headline, 24px); font-weight: 700; margin: 0 0 12px; color: var(--pc-color-text-primary); }
      .page-cta p { font-size: var(--pc-text-body, 16px); color: var(--pc-color-text-secondary); margin: 0 0 24px; max-width: 560px; margin-left: auto; margin-right: auto; }
      .cta-buttons { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
      .btn-primary, .btn-secondary { display: inline-flex; align-items: center; padding: 10px 24px; border-radius: var(--pc-radius-sm, 6px); font-size: var(--pc-text-body-sm, 14px); font-weight: 500; text-decoration: none; transition: all var(--pc-duration-fast, 150ms); }
      .btn-primary { background: var(--pc-color-accent-default); color: var(--pc-color-text-inverse, #fff); border: 1px solid var(--pc-color-accent-default); }
      .btn-primary:hover { background: var(--pc-color-accent-hover); border-color: var(--pc-color-accent-hover); }
      .btn-secondary { background: transparent; color: var(--pc-color-text-primary); border: 1px solid var(--pc-color-border-strong); }
      .btn-secondary:hover { border-color: var(--pc-color-accent-default); color: var(--pc-color-accent-default); }
      .container-narrow { max-width: 800px; margin: 0 auto; padding: 0 24px; }
    </style>
  </body>
</html>
